<main class="min-h-screen bg-[#121212] text-white sm:bg-white sm:text-slate-900">
  <section class="w-full px-6 pt-12 sm:px-10 sm:pt-16 lg:px-16">
    <div class="mx-auto w-full max-w-6xl text-center">
      <div class="text-3xl font-semibold text-white sm:text-slate-900">Price Check</div>
      <p class="mt-3 text-sm text-slate-300 sm:text-slate-500">Live price discovery across Ghanaian stores and global marketplaces.</p>

      <div class="mt-8">
        <%= form_with url: search_path, method: :post, data: { turbo_frame: "results", loading_target: true } do |form| %>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <div class="flex w-full items-center gap-3 rounded-full border border-white/10 bg-[#2a2a2a] px-5 py-3 text-white focus-within:border-white/20 focus-within:shadow-none sm:border-slate-200 sm:bg-white sm:text-slate-700 sm:focus-within:border-slate-300">
              <span class="text-slate-400">🔎</span>
              <%= form.text_field :query, placeholder: "Search for a product",
                class: "search-input w-full appearance-none border-0 bg-transparent text-sm text-white placeholder:text-slate-400 focus:border-transparent focus:outline-none focus:ring-0 focus-visible:outline-none focus-visible:ring-0 focus:shadow-none focus-visible:shadow-none sm:text-slate-700" %>
            </div>
            <div class="flex w-full items-center gap-2 rounded-full border border-white/10 bg-[#2a2a2a] px-4 py-3 text-white focus-within:border-white/20 sm:border-slate-200 sm:bg-white sm:text-slate-700 sm:focus-within:border-slate-300 sm:max-w-[260px] hidden sm:flex">
              <span class="text-[10px] font-semibold uppercase tracking-[0.3em] text-slate-400">Budget</span>
              <%= form.number_field :min_price, placeholder: "Min",
                class: "search-input w-20 border-0 bg-transparent text-xs text-white placeholder:text-slate-400 focus:outline-none focus:ring-0 sm:text-slate-700" %>
              <span class="text-slate-500">–</span>
              <%= form.number_field :max_price, placeholder: "Max",
                class: "search-input w-20 border-0 bg-transparent text-xs text-white placeholder:text-slate-400 focus:outline-none focus:ring-0 sm:text-slate-700" %>
            </div>
            <%= form.submit "Search", class: "hidden h-11 rounded-full bg-white px-6 text-xs font-semibold uppercase tracking-[0.3em] text-slate-900 transition hover:bg-slate-100 sm:inline-flex sm:bg-slate-900 sm:text-white sm:hover:bg-slate-800" %>
          </div>
          <button type="button" data-budget-toggle class="mt-3 inline-flex items-center justify-center rounded-full border border-white/10 px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.3em] text-slate-200 sm:hidden">
            Set your budget
          </button>
          <div data-budget-panel class="mt-3 hidden items-center gap-2 rounded-full border border-white/10 bg-[#2a2a2a] px-4 py-3 text-white sm:hidden">
            <span class="text-[10px] font-semibold uppercase tracking-[0.3em] text-slate-400">Budget</span>
            <%= form.number_field :min_price, placeholder: "Min",
              class: "search-input w-20 border-0 bg-transparent text-xs text-white placeholder:text-slate-400 focus:outline-none focus:ring-0" %>
            <span class="text-slate-500">–</span>
            <%= form.number_field :max_price, placeholder: "Max",
              class: "search-input w-20 border-0 bg-transparent text-xs text-white placeholder:text-slate-400 focus:outline-none focus:ring-0" %>
          </div>

          <div class="mt-4 flex flex-wrap items-center justify-center gap-3 text-xs text-slate-300 sm:text-slate-500">
            <span class="text-[10px] font-semibold uppercase tracking-[0.3em] text-slate-400">Stores</span>
            <% @stores.each do |store| %>
              <label class="flex items-center gap-2 rounded-full border border-white/10 px-4 py-2 sm:border-slate-200">
                <%= check_box_tag "stores[]", store, true, class: "h-4 w-4 rounded text-white sm:text-slate-900" %>
                <% if store_logo_url(store) %>
                  <img src="<%= store_logo_url(store) %>" alt="<%= store %> logo" class="h-4 w-auto max-w-[36px] object-contain">
                <% end %>
                <span class="text-[12px] font-medium text-slate-200 sm:text-slate-600"><%= store %></span>
              </label>
            <% end %>
          </div>
        <% end %>

        <div data-loading-indicator class="hidden mt-4 text-xs text-slate-300 sm:text-slate-500">
          Scanning live stores now… this can take a few seconds.
        </div>
      </div>
    </div>
  </section>

  <section class="w-full px-6 pb-16 pt-6 sm:px-10 sm:pt-10 lg:px-16" data-results-container>
    <%= turbo_frame_tag "results" do %>
      <%= render "searches/results", results: @results, query: @query %>
    <% end %>
  </section>
</main>
